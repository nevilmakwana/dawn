<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- FontAwesome -->
    <script>
      window.FontAwesomeConfig = { autoReplaceSvg: 'nest' };
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ink: '#000000',
              surface: '#ffffff',
              surface2: '#f9f9f9',
              surface3: '#f1f1f1',
              line: '#e5e5e5',
              muted: '#9e9e9e',
            },
            fontFamily: {
              sans: ['Inter', 'sans-serif'],
              display: ['"Playfair Display"', 'serif'],
            },
            keyframes: {
              slide: {
                from: { transform: 'translateX(0)' },
                to: { transform: 'translateX(-50%)' },
              },
            },
            animation: {
              slide: 'slide 30s linear infinite',
            },
          },
        },
      };
    </script>
    <style>
      .animate-slide { animation: slide 30s linear infinite; }
      .nav-link::after {
          content: '';
          position: absolute;
          bottom: 0;
          left: 0;
          width: 0;
          height: 1px;
          background-color: currentColor;
          transition: width 0.3s ease;
      }
      .nav-link:hover::after { width: 100%; }
    </style>

    {{ content_for_header }}

    <!-- Swiper.js for Carousels -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer="defer"></script>

    <!-- Luxury Theme CSS -->
    {{ 'theme-variables.css' | asset_url | stylesheet_tag }}
    {{ 'luxury-base.css' | asset_url | stylesheet_tag }}
    {{ 'luxury-header.css' | asset_url | stylesheet_tag }}
    {{ 'luxury-homepage.css' | asset_url | stylesheet_tag }}
    {{ 'luxury-collection.css' | asset_url | stylesheet_tag }}
    {{ 'luxury-product.css' | asset_url | stylesheet_tag }}
    {{ 'luxury-cart.css' | asset_url | stylesheet_tag }}
    {{ 'luxury-footer.css' | asset_url | stylesheet_tag }}
    {{ 'luxury-pages.css' | asset_url | stylesheet_tag }}
  </head>
  
  <body class="bg-surface text-gray-900 antialiased overflow-x-hidden">
    {% section 'luxury-header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'luxury-footer' %}
    {% render 'luxury-cart-drawer' %}

    <!-- Luxury Theme JS -->
    <script src="{{ 'luxury-header.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'luxury-footer.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'luxury-cart.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'luxury-product.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
