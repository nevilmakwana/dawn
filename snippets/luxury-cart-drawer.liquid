{{ 'luxury-cart.css' | asset_url | stylesheet_tag }}
<script src="{{ 'luxury-cart.js' | asset_url }}" defer="defer"></script>

<div id="CartOverlay" class="cart-drawer-overlay js-cart-close"></div>

<div id="CartDrawer" class="cart-drawer">
  <div class="cart-drawer__header">
    <h2 class="cart-drawer__title">Your Bag</h2>
    <button type="button" class="cart-drawer__close js-cart-close" aria-label="Close cart">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div class="cart-drawer__body">
    {%- if cart.item_count > 0 -%}
      <div class="cart-items">
        {%- for item in cart.items -%}
          <div class="cart-item">
            <a href="{{ item.url }}" class="cart-item__media">
              {%- if item.image -%}
                {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy' }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </a>
            
            <div class="cart-item__info">
              <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
              
              {%- unless item.product.has_only_default_variant -%}
                <div class="cart-item__options">
                  {{ item.variant.title }}
                </div>
              {%- endunless -%}
              
              <div class="cart-item__price">
                {{ item.final_line_price | money }}
              </div>
              
              <div class="cart-item__actions">
                <div class="cart-quantity">
                  <button type="button" onclick="this.nextElementSibling.stepDown(); this.nextElementSibling.dispatchEvent(new Event('change'))">-</button>
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Quantity">
                  <button type="button" onclick="this.previousElementSibling.stepUp(); this.previousElementSibling.dispatchEvent(new Event('change'))">+</button>
                </div>
                <a href="{{ item.url_to_remove }}" class="cart-item__remove">Remove</a>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <!-- Fallback / Empty State -->
      <div class="cart-drawer__empty">
        <p>Your bag is currently empty.</p>
        <button class="btn btn--primary js-cart-close">Continue Shopping</button>
      </div>
    {%- endif -%}
  </div>

  <div class="cart-drawer__footer">
    <div class="cart-subtotal">
      <span>Subtotal</span>
      <span>{{ cart.total_price | money }}</span>
    </div>
    <p class="cart-disclaimer">Taxes and shipping calculated at checkout.</p>
    <a href="{{ routes.cart_url }}" class="btn btn--primary btn-checkout">View Bag</a>
  </div>
</div>
