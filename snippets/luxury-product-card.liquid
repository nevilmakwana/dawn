{%- comment -%}
  Accepts:
  - product_card_product: {Object} Product Liquid object (required)
  - show_secondary_image: {Boolean} Show the secondary image on hover. Default: false (optional)
  - show_vendor: {Boolean} Show the product vendor. Default: false
{%- endcomment -%}

<a href="{{ product_card_product.url | default: '#' }}" class="product-card">
  <div class="product-card__media">
    {%- if product_card_product.featured_media -%}
      {{ product_card_product.featured_media | image_url: width: 600 | image_tag: class: 'primary-image', loading: 'lazy' }}
      {%- if product_card_product.media[1] != blank and show_secondary_image -%}
        {{ product_card_product.media[1] | image_url: width: 600 | image_tag: class: 'secondary-image', loading: 'lazy' }}
      {%- endif -%}
    {%- else -%}
      <img src="https://images.unsplash.com/photo-1543163521-1bf539c55dd2?q=80&w=600&auto=format&fit=crop" alt="Product" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
    {%- endif -%}
  </div>

  {%- if show_vendor -%}
    <div class="product-card__vendor">{{ product_card_product.vendor }}</div>
  {%- endif -%}

  <h3 class="product-card__title">{{ product_card_product.title | default: 'Luxury Item' }}</h3>
  
  <div class="product-card__price">
    {%- if product_card_product.compare_at_price > product_card_product.price -%}
      <s style="color: var(--color-grey-400); margin-right: 4px;">{{ product_card_product.compare_at_price | money }}</s>
    {%- endif -%}
    {{ product_card_product.price | default: 120000 | money }}
  </div>
</a>
