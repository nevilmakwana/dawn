<!-- Luxury Footer -->
<footer class="prada-footer">
  <div class="prada-footer__top">
    <!-- Newsletter & Social -->
    <div class="prada-footer__newsletter-col">
      <h3 class="prada-footer__heading">Newsletter</h3>
      <form action="{{ routes.newsletter_url }}" method="post" class="prada-footer__form">
        <input type="email" name="email" placeholder="Email address" class="prada-footer__input" required>
        <button type="submit" class="prada-footer__submit">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </form>
      <div class="prada-footer__social">
        <a href="#">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a href="#">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
        </a>
        <a href="#">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Links Grid -->
    <div class="prada-footer__links-grid">
      <ul class="prada-footer__list">
        <li><a href="#">New Arrivals</a></li>
        <li><a href="#">Women</a></li>
        <li><a href="#">Men</a></li>
        <li><a href="#">Handbags</a></li>
        <li><a href="#">Accessories</a></li>
      </ul>
      <ul class="prada-footer__list">
        <li><a href="#">About</a></li>
        <li><a href="#">Sustainability</a></li>
        <li><a href="#">Careers</a></li>
        <li><a href="#">Press</a></li>
      </ul>
      <ul class="prada-footer__list">
        <li><a href="#">Contact</a></li>
        <li><a href="#">Shipping</a></li>
        <li><a href="#">Returns</a></li>
        <li><a href="#">FAQ</a></li>
      </ul>
      <ul class="prada-footer__list">
        <li><a href="#">My Account</a></li>
        <li><a href="#">Order Status</a></li>
        <li><a href="#">Wishlist</a></li>
      </ul>
    </div>
  </div>

  <!-- Bottom -->
  <div class="prada-footer__bottom">
    <p>© {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved</p>
    <div class="prada-footer__actions">
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Use</a>
      <a href="#">Cookie Settings</a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Luxury Footer",
  "settings": []
}
{% endschema %}
