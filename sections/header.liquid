    .section-header:has(.prada-header .header__search details[open]) .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header-btn__icon svg,
    .section-header:has(.prada-header .header__search details[open]) .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header header-drawer summary svg,
    .section-header:has(.prada-header .header__search details[open]) .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header .header__search summary svg {
      stroke: #000000 !important;
      color: #000000 !important;
    }

    .section-header.menu-open .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header-logo .has-hover-logo .default-logo,
    .section-header:has(.prada-header .header__search details[open]) .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header-logo .has-hover-logo .default-logo {
      display: none !important;
    }

    .section-header.menu-open .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header-logo .has-hover-logo .hover-logo,
    .section-header:has(.prada-header .header__search details[open]) .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header-logo .has-hover-logo .hover-logo {
      display: block !important;
    }
  }

  /* Logo base definitions */
  .prada-header-logo .hover-logo {
    display: none !important;
  }
  .prada-header-logo .default-logo {
    display: block !important;
  }

  /* Center logo vertically and remove baseline gaps */
  .prada-header-logo {
    display: flex !important;
    align-items: center !important;
    padding: 0 !important;
    margin: 0 !important;
    line-height: 0 !important;
  }

  /* Keep every header glyph at the same visual scale. */
  .prada-header .prada-header-btn__icon svg,
  .prada-header header-drawer summary .prada-menu-icon-wrapper svg,
  .prada-header .header__search summary .svg-wrapper:not(.header__icon-close) svg {
    width: 20px !important;
    height: 20px !important;
    transform: scale(1.15) !important;
  }

  /* Explicit hamburger and close states avoid Dawn's default icon swap. */
  .prada-header header-drawer > details > summary .prada-menu-icon-wrapper {
    position: relative !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 24px !important;
    height: 24px !important;
  }

  .prada-header header-drawer > details > summary .prada-menu-glyph,
  .prada-header header-drawer > details > summary .prada-close-glyph {
    position: absolute !important;
    width: 20px !important;
    height: 20px !important;
    fill: none !important;
    transition: opacity 160ms ease, transform 160ms ease, visibility 160ms ease;
  }

  .prada-header header-drawer > details > summary .prada-menu-glyph {
    opacity: 1 !important;
    visibility: visible !important;
    transform: scale(1.15) !important;
  }

  .prada-header header-drawer > details > summary .prada-close-glyph {
    opacity: 0 !important;
    visibility: hidden !important;
    transform: scale(0.85) !important;
  }

  .prada-header header-drawer > details[open] > summary .prada-menu-glyph {
    opacity: 0 !important;
    visibility: hidden !important;
    transform: scale(0.85) !important;
  }

  .prada-header header-drawer > details[open] > summary .prada-close-glyph {
    opacity: 1 !important;
    visibility: visible !important;
    transform: scale(1.15) !important;
  }
  .prada-header header-drawer > details > summary.prada-menu-summary,
  .prada-header header-drawer > details > summary.prada-menu-summary:focus,
  .prada-header header-drawer > details > summary.prada-menu-summary:focus-visible {
    outline: 0 !important;
    box-shadow: none !important;
  }

</style>

{%- style -%}
