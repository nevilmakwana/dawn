<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link
  rel="stylesheet"
  href="{{ 'component-cart-notification.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<style>
  /* ========================================
     PRADA-STYLE HEADER - Pixel-Perfect Copy
     Based on actual prada.com source code
     ======================================== */

  /* Reset Dawn's default header-drawer styles */
  header-drawer {
    justify-self: start;
    margin-left: 0;
  }

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 0.5rem;
    padding-top: 0.5rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  /* ---- Section Header Wrapper ---- */
  .section-header {
    position: fixed !important;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    margin-bottom: 0 !important;
    border: none !important;
  }

  .header-wrapper {
    background: rgba(255, 255, 255, 0) !important;
    border: none !important;
    box-shadow: none !important;
  }

  .header-wrapper--border-bottom {
    border-bottom: none !important;
  }

  /* ---- Prada Header Container ---- */
  .prada-header {
    display: flex !important;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 14px 20px !important;
    background: rgba(255, 255, 255, 0) !important;
    border: none !important;
    grid-template-columns: none !important;
    column-gap: 0 !important;
  }

  @media screen and (min-width: 990px) {
    .prada-header {
      padding: 16px 24px !important;
    }
  }

  /* ---- Three Column Layout ---- */
  .prada-header-left,
  .prada-header-center,
  .prada-header-right {
    display: flex;
    align-items: center;
  }

  .prada-header-left {
    flex: 1;
    justify-content: flex-start;
    gap: 0;
  }

  .prada-header-center {
    flex: 0 0 auto;
    justify-content: center;
  }

  .prada-header-right {
    flex: 1;
    justify-content: flex-end;
    gap: 0;
  }

  /* ---- Prada Buttons (Menu, Search, Contact, etc.) ---- */
  .prada-header-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: none;
    color: #fff;
    padding: 8px 10px;
    transition: opacity 0.2s ease;
    position: relative;
  }

  .prada-header-btn:hover {
    opacity: 0.7;
  }

  .prada-header-btn__label {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: capitalize;
    color: #fff;
    white-space: nowrap;
    line-height: 1;
  }

  .prada-header-btn__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
  }

  .prada-header-btn__icon svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: #fff;
    color: #fff;
  }

  /* Hamburger icon override */
  .prada-header-btn--menu .prada-header-btn__icon svg {
    width: 24px;
    height: 24px;
  }

  /* Cart badge */
  .prada-cart-badge {
    position: absolute;
    top: 2px;
    right: 2px;
    min-width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #fff;
    color: #000;
    font-size: 9px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    padding: 0 4px;
  }

  .prada-cart-badge--empty {
    display: none;
  }

  /* ---- Logo ---- */
  .prada-header-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #fff;
    padding: 0 20px;
  }

  .prada-header-logo .header__heading-logo-wrapper {
    margin: 0;
    width: auto;
  }

  .prada-header-logo .header__heading-logo {
    width: auto;
    max-width: 200px;
    height: auto;
    max-height: 36px;
  }

  .prada-text-logo {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 26px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
    white-space: nowrap;
    line-height: 1;
  }

  @media screen and (min-width: 990px) {
    .prada-text-logo {
      font-size: 34px;
      letter-spacing: 0.3em;
    }
  }

  .prada-header .header__heading {
    margin: 0;
    line-height: 1;
  }

  /* ---- Dawn Overrides ---- */
  .prada-header .header__icons {
    display: flex !important;
    align-items: center;
    gap: 0;
    width: auto !important;
    flex: 1;
    justify-content: flex-end;
    padding: 0 !important;
  }

  /* Hide Dawn's default search in header icons */
  .prada-header .header__icons .header__search {
    display: none !important;
  }

  .prada-header .prada-header-left > .header__search {
    display: inline-flex !important;
    flex: 0 0 auto;
    position: relative;
    z-index: 4;
  }

  /* Override Dawn header-drawer margin */
  .prada-header header-drawer {
    margin-left: 0 !important;
    display: flex !important;
  }

  /* Ensure header-drawer's summary uses our button style */
  .prada-header header-drawer summary.header__icon {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #fff;
    padding: 8px 10px;
    margin: 0;
    opacity: 1;
  }

  .prada-header header-drawer summary.header__icon:hover {
    opacity: 0.7;
  }

  .prada-header header-drawer summary .prada-menu-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  .prada-header header-drawer summary .prada-menu-icon-wrapper svg {
    width: 20px;
    height: 20px;
    stroke: #fff;
    color: #fff;
  }

  .prada-header header-drawer summary .prada-menu-text {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: capitalize;
    color: #fff;
    line-height: 1;
  }

  /* Search button in header (the details-modal summary) */
  .prada-header .header__search summary.header__icon {
    display: flex !important;
    align-items: center;
    gap: 8px;
    color: #fff;
    padding: 8px 10px;
  }

  .prada-header .header__search summary .svg-wrapper:not(.header__icon-close),
  .prada-header .header__search summary .prada-search-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  .prada-header .header__search summary .svg-wrapper:not(.header__icon-close) svg,
  .prada-header .header__search summary .prada-search-icon-wrapper svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: #fff;
    color: #fff;
  }

  .prada-header .header__search summary .prada-search-text {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: capitalize;
    color: #fff;
    line-height: 1;
  }

  /* Account icon override */
  .prada-header .header__icon--account {
    color: #fff !important;
    padding: 8px 10px;
  }

  .prada-header .header__icon--account svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: #fff;
    color: #fff;
  }

  .prada-header .header__icon--account .svg-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  /* Remove .small-hide from account on Prada header */
  .prada-header .header__icon--account.small-hide {
    display: flex !important;
  }

  /* Cart icon override */
  .prada-header .header__icon--cart {
    color: #fff !important;
    padding: 8px 10px;
    position: relative;
  }

  .prada-header .header__icon--cart svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: #fff;
    color: #fff;
  }

  .prada-header .header__icon--cart .svg-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  /* Hide Dawn's default cart count bubble */
  .prada-header .cart-count-bubble {
    display: none !important;
  }

  .prada-desktop-menu {
    display: none;
  }

  /* ---- Responsive: Desktop (990px+) ---- */
  @media screen and (min-width: 990px) {
    header-drawer {
      display: flex !important;
    }

    .section-header.menu-open {
      z-index: 2100 !important;
    }

    .js .prada-header header-drawer > details > summary::before,
    .js .prada-header header-drawer > details[open]:not(.menu-opening) > summary::before {
      position: fixed !important;
      inset: 0 !important;
      width: 100vw !important;
      height: 100dvh !important;
      content: '';
      background: rgba(0, 0, 0, 0.68) !important;
      cursor: default;
      opacity: 0;
      visibility: hidden;
      z-index: 1998 !important;
      transition: opacity 220ms ease, visibility 220ms ease;
    }

    .prada-header header-drawer > details[open] > summary::before {
      opacity: 1 !important;
      visibility: visible !important;
    }

    .prada-header .menu-drawer {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      width: min(480px, 25vw) !important;
      max-width: 1440px !important;
      height: 100dvh !important;
      padding: 0 !important;
      overflow: hidden !important;
      visibility: hidden;
      transform: translateX(-105%) !important;
      background: #ffffff !important;
      border: 0 !important;
      box-shadow: none !important;
      filter: none !important;
      z-index: 1999 !important;
      transition: transform 280ms cubic-bezier(0.22, 1, 0.36, 1), width 280ms cubic-bezier(0.22, 1, 0.36, 1), visibility 280ms ease !important;
    }

    .prada-header .menu-drawer[data-prada-menu-level='2'] {
      width: min(960px, 50vw) !important;
    }

    .prada-header .menu-drawer[data-prada-menu-level='3'] {
      width: min(1440px, 75vw) !important;
    }

    .js .prada-header header-drawer > details[open].menu-opening > .menu-drawer {
      visibility: visible !important;
      transform: translateX(0) !important;
    }

    .prada-header .menu-drawer__inner-container,
    .prada-header .menu-drawer__navigation-container {
      display: block !important;
      width: 100% !important;
      height: 100% !important;
      overflow: hidden !important;
      background: #ffffff !important;
    }

    .prada-header .menu-drawer__navigation,
    .prada-header .menu-drawer__utility-links {
      display: none !important;
    }

    .prada-desktop-menu {
      position: relative;
      display: block !important;
      width: 100%;
      height: 100%;
      background: #ffffff;
      color: #111111;
    }

    .prada-desktop-menu__toolbar {
      position: absolute;
      top: 0;
      right: 0;
      left: 0;
      z-index: 3;
      display: flex;
      align-items: center;
      gap: 28px;
      height: 88px;
      padding: 0 36px;
      background: #ffffff;
    }

    .prada-desktop-menu__toolbar-button {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      min-height: 32px;
      padding: 0;
      border: 0;
      background: transparent;
      color: #111111;
      font: inherit;
      font-size: 14px;
      font-weight: 500;
      line-height: 1;
      cursor: pointer;
    }

    .prada-desktop-menu__toolbar-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 20px;
      height: 20px;
    }

    .prada-desktop-menu__toolbar-icon svg {
      width: 19px;
      height: 19px;
      fill: none;
      stroke: currentColor;
    }

    .prada-desktop-menu__primary {
      position: relative;
      width: 100%;
      height: 100%;
      padding: 112px 40px 180px;
      overflow: visible;
    }

    .prada-header .menu-drawer[data-prada-menu-level='2'] .prada-desktop-menu__primary {
      width: 50%;
    }

    .prada-header .menu-drawer[data-prada-menu-level='3'] .prada-desktop-menu__primary {
      width: 33.333%;
    }

    .prada-desktop-menu__item {
      position: static;
      margin: 0;
    }

    .prada-desktop-menu__primary-control,
    .prada-desktop-menu__submenu-control {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      clip-path: inset(50%);
      white-space: nowrap;
    }

    .prada-desktop-menu__primary-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 48px;
      padding: 0;
      color: #777777;
      text-decoration: none;
      font-size: 16px;
      font-weight: 500;
      line-height: 1.3;
      cursor: pointer;
      transition: color 160ms ease;
    }

    .prada-desktop-menu__primary-link:hover,
    .prada-desktop-menu__primary-link:focus-visible,
    .prada-desktop-menu__primary-control:checked + .prada-desktop-menu__primary-link {
      color: #111111;
    }

    .prada-desktop-menu__primary-control:checked + .prada-desktop-menu__primary-link {
      font-weight: 700;
    }

    .prada-desktop-menu__primary-control:focus-visible + .prada-desktop-menu__primary-link,
    .prada-desktop-menu__submenu-control:focus-visible + .prada-desktop-menu__submenu-link {
      outline: 1px solid #111111;
      outline-offset: 5px;
    }

    .prada-desktop-menu__chevron {
      display: inline-flex;
      margin-left: 16px;
      color: currentColor;
      font-size: 20px;
      font-weight: 400;
      line-height: 1;
    }

    .prada-desktop-menu__submenu {
      position: absolute;
      top: 0;
      left: 100%;
      display: none;
      width: 100%;
      height: 100%;
      padding: 112px 40px 48px;
      overflow: visible;
      border-left: 1px solid #e6e6e6;
      background: #ffffff;
    }

    .prada-desktop-menu__primary-control:checked ~ .prada-desktop-menu__submenu {
      display: block;
    }

    .prada-desktop-menu__submenu-list,
    .prada-desktop-menu__grandchild-list {
      display: grid;
      gap: 0;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .prada-desktop-menu__submenu-list > li {
      position: static;
      margin: 0;
    }

    .prada-desktop-menu__submenu-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 48px;
      color: #111111;
      text-decoration: none;
      font-size: 16px;
      font-weight: 500;
      line-height: 1.3;
      cursor: pointer;
    }

    .prada-desktop-menu__submenu-link:hover,
    .prada-desktop-menu__submenu-link:focus-visible,
    .prada-desktop-menu__submenu-control:checked + .prada-desktop-menu__submenu-link {
      color: #111111;
    }

    .prada-desktop-menu__submenu-link:hover,
    .prada-desktop-menu__submenu-link:focus-visible,
    .prada-desktop-menu__submenu-control:checked + .prada-desktop-menu__submenu-link {
      text-decoration: underline;
      text-underline-offset: 4px;
    }

    .prada-desktop-menu__submenu-control:checked + .prada-desktop-menu__submenu-link {
      font-weight: 700;
    }

    .prada-desktop-menu__grandchild-panel {
      position: absolute;
      top: 0;
      left: 100%;
      z-index: 1;
      display: none;
      width: 100%;
      height: 100%;
      padding: 112px 40px 48px;
      overflow: visible;
      border-left: 1px solid #e6e6e6;
      background: #ffffff;
    }

    .prada-desktop-menu__submenu-control:checked ~ .prada-desktop-menu__grandchild-panel {
      display: block;
    }

    .prada-desktop-menu__view-all,
    .prada-desktop-menu__grandchild-list a {
      display: inline-block;
      color: #111111;
      text-decoration: none;
      font-size: 16px;
      font-weight: 500;
      line-height: 1.3;
    }

    .prada-desktop-menu__view-all {
      margin-bottom: 32px;
    }

    .prada-desktop-menu__view-all:hover,
    .prada-desktop-menu__view-all:focus-visible,
    .prada-desktop-menu__grandchild-list a:hover,
    .prada-desktop-menu__grandchild-list a:focus-visible {
      text-decoration: underline;
      text-underline-offset: 4px;
    }

    .prada-desktop-menu__grandchild-list {
      gap: 18px;
    }

    .prada-desktop-menu__utility {
      position: absolute;
      bottom: 34px;
      left: 36px;
      z-index: 2;
      display: grid;
      gap: 15px;
      width: calc(100% - 72px);
    }

    .prada-header .menu-drawer[data-prada-menu-level='2'] .prada-desktop-menu__utility {
      width: calc(50% - 72px);
    }

    .prada-header .menu-drawer[data-prada-menu-level='3'] .prada-desktop-menu__utility {
      width: calc(33.333% - 72px);
    }

    .prada-desktop-menu__utility a {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      color: #111111;
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      line-height: 1.2;
    }

    .prada-desktop-menu__utility a:hover,
    .prada-desktop-menu__utility a:focus-visible {
      text-decoration: underline;
      text-underline-offset: 4px;
    }

    .prada-desktop-menu__utility svg {
      width: 18px;
      height: 18px;
      flex: 0 0 18px;
      fill: none;
      stroke: currentColor;
    }

    .section-header:has(.prada-header .header__search details[open]) {
      z-index: 1400 !important;
    }

    .prada-header .header__search details {
      position: static !important;
    }

    .prada-header .header__search details[open] > .search-modal {
      --prada-desktop-search-height: 400px;
      position: fixed !important;
      inset: 0 auto auto 0 !important;
      width: 100vw !important;
      height: var(--prada-desktop-search-height) !important;
      min-height: 0 !important;
      overflow: visible !important;
      opacity: 1 !important;
      animation: none !important;
      background: #ffffff !important;
      border: 0 !important;
      box-shadow: none !important;
      z-index: 2000 !important;
    }

    .prada-header .search-modal .modal-overlay {
      position: fixed !important;
      top: var(--prada-desktop-search-height) !important;
      right: 0 !important;
      bottom: 0 !important;
      left: 0 !important;
      display: block !important;
      background: rgba(0, 0, 0, 0.62) !important;
      z-index: 0 !important;
    }

    .prada-header .search-modal .modal-overlay::after {
      display: none !important;
      content: none !important;
    }

    .prada-header .search-modal__content {
      display: grid !important;
      grid-template-columns: minmax(0, 1fr) auto !important;
      grid-template-rows: 66px 1fr !important;
      align-items: start !important;
      width: 100% !important;
      height: var(--prada-desktop-search-height) !important;
      padding: 0 20px !important;
      background: #ffffff !important;
      position: relative !important;
      z-index: 1 !important;
    }

    .prada-header .search-modal__content > predictive-search,
    .prada-header .search-modal__content > search-form {
      grid-column: 1 !important;
      grid-row: 1 !important;
      width: 100% !important;
      max-width: none !important;
    }

    .prada-header .search-modal__form {
      width: 100% !important;
      max-width: none !important;
    }

    .prada-header .search-modal .field {
      height: 66px !important;
      border: 0 !important;
      border-bottom: 1px solid #111111 !important;
      border-radius: 0 !important;
      background: transparent !important;
      box-shadow: none !important;
    }

    .prada-header .search-modal .field::before,
    .prada-header .search-modal .field::after {
      display: none !important;
      content: none !important;
    }

    .prada-header .search-modal .field__input {
      height: 65px !important;
      min-height: 65px !important;
      padding: 0 !important;
      color: #111111 !important;
      background: transparent !important;
      box-shadow: none !important;
      font-size: 14px !important;
      font-weight: 600 !important;
    }

    .prada-header .search-modal .field__label,
    .prada-header .search-modal .field__button {
      display: none !important;
    }

    .prada-header .search-modal__close-button {
      position: static !important;
      grid-column: 2 !important;
      grid-row: 1 !important;
      width: auto !important;
      height: 66px !important;
      margin: 0 0 0 24px !important;
      padding: 0 !important;
      color: #111111 !important;
      background: transparent !important;
      font-size: 12px !important;
      font-weight: 700 !important;
      letter-spacing: 0 !important;
      line-height: 66px !important;
      text-decoration: underline !important;
      text-transform: uppercase !important;
    }

    .prada-header .search-modal__close-button .prada-search-close-label {
      display: block !important;
    }

    .prada-header .search-modal__close-button .prada-search-close-icon {
      display: none !important;
    }

    .prada-mobile-search-links {
      display: grid !important;
