<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link
  rel="stylesheet"
  href="{{ 'component-cart-notification.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<style>
  /* ========================================
     PRADA-STYLE HEADER - Pixel-Perfect Copy
     Based on actual prada.com source code
     ======================================== */

  /* Reset Dawn's default header-drawer styles */
  header-drawer {
    justify-self: start;
    margin-left: 0;
  }

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 0.5rem;
    padding-top: 0.5rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  /* ---- Section Header Wrapper ---- */
  .section-header {
    position: fixed !important;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    margin-bottom: 0 !important;
    border: none !important;
  }

  .header-wrapper {
    background: rgba(255, 255, 255, 0) !important;
    border: none !important;
    box-shadow: none !important;
  }

  .header-wrapper--border-bottom {
    border-bottom: none !important;
  }

  /* ---- Prada Header Container ---- */
  .prada-header {
    display: flex !important;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 14px 20px !important;
    background: rgba(255, 255, 255, 0) !important;
    border: none !important;
    grid-template-columns: none !important;
    column-gap: 0 !important;
  }

  @media screen and (min-width: 990px) {
    .prada-header {
      padding: 16px 24px !important;
    }
  }

  /* ---- Three Column Layout ---- */
  .prada-header-left,
  .prada-header-center,
  .prada-header-right {
    display: flex;
    align-items: center;
  }

  .prada-header-left {
    flex: 1;
    justify-content: flex-start;
    gap: 0;
  }

  .prada-header-center {
    flex: 0 0 auto;
    justify-content: center;
  }

  .prada-header-right {
    flex: 1;
    justify-content: flex-end;
    gap: 0;
  }

  /* ---- Prada Buttons (Menu, Search, Contact, etc.) ---- */
  .prada-header-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: none;
    color: #fff;
    padding: 8px 10px;
    transition: opacity 0.2s ease;
    position: relative;
  }

  .prada-header-btn:hover {
    opacity: 0.7;
  }

  .prada-header-btn__label {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: capitalize;
    color: #fff;
    white-space: nowrap;
    line-height: 1;
  }

  .prada-header-btn__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
  }

  .prada-header-btn__icon svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: #fff;
    color: #fff;
  }

  /* Hamburger icon override */
  .prada-header-btn--menu .prada-header-btn__icon svg {
    width: 24px;
    height: 24px;
  }

  /* Cart badge */
  .prada-cart-badge {
    position: absolute;
    top: 2px;
    right: 2px;
    min-width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #fff;
    color: #000;
    font-size: 9px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    padding: 0 4px;
  }

  .prada-cart-badge--empty {
    display: none;
  }

  /* ---- Logo ---- */
  .prada-header-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #fff;
    padding: 0 20px;
  }

  .prada-header-logo .header__heading-logo-wrapper {
    margin: 0;
    width: auto;
  }

  .prada-header-logo .header__heading-logo {
    width: auto;
    max-width: 200px;
    height: auto;
    max-height: 36px;
  }

  .prada-text-logo {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 26px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
    white-space: nowrap;
    line-height: 1;
  }

  @media screen and (min-width: 990px) {
    .prada-text-logo {
      font-size: 34px;
      letter-spacing: 0.3em;
    }
  }

  .prada-header .header__heading {
    margin: 0;
    line-height: 1;
  }

  /* ---- Dawn Overrides ---- */
  .prada-header .header__icons {
    display: flex !important;
    align-items: center;
    gap: 0;
    width: auto !important;
    flex: 1;
    justify-content: flex-end;
    padding: 0 !important;
  }

  /* Hide Dawn's default search in header icons */
  .prada-header .header__icons .header__search {
    display: none !important;
  }

  /* Override Dawn header-drawer margin */
  .prada-header header-drawer {
    margin-left: 0 !important;
    display: flex !important;
  }

  /* Ensure header-drawer's summary uses our button style */
  .prada-header header-drawer summary.header__icon {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #fff;
    padding: 8px 10px;
    margin: 0;
    opacity: 1;
  }

  .prada-header header-drawer summary.header__icon:hover {
    opacity: 0.7;
  }

  .prada-header header-drawer summary .prada-menu-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  .prada-header header-drawer summary .prada-menu-icon-wrapper svg {
    width: 20px;
    height: 20px;
    stroke: #fff;
    color: #fff;
  }

  .prada-header header-drawer summary .prada-menu-text {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: capitalize;
    color: #fff;
    line-height: 1;
  }

  /* Search button in header (the details-modal summary) */
  .prada-header .header__search summary.header__icon {
    display: flex !important;
    align-items: center;
    gap: 8px;
    color: #fff;
    padding: 8px 10px;
  }

  .prada-header .header__search summary .prada-search-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  .prada-header .header__search summary .prada-search-icon-wrapper svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: #fff;
    color: #fff;
  }

  .prada-header .header__search summary .prada-search-text {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: capitalize;
    color: #fff;
    line-height: 1;
  }

  /* Account icon override */
  .prada-header .header__icon--account {
    color: #fff !important;
    padding: 8px 10px;
  }

  .prada-header .header__icon--account svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: #fff;
    color: #fff;
  }

  .prada-header .header__icon--account .svg-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  /* Remove .small-hide from account on Prada header */
  .prada-header .header__icon--account.small-hide {
    display: flex !important;
  }

  /* Cart icon override */
  .prada-header .header__icon--cart {
    color: #fff !important;
    padding: 8px 10px;
    position: relative;
  }

  .prada-header .header__icon--cart svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: #fff;
    color: #fff;
  }

  .prada-header .header__icon--cart .svg-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  /* Hide Dawn's default cart count bubble */
  .prada-header .cart-count-bubble {
    display: none !important;
  }

  /* ---- Responsive: Desktop (990px+) ---- */
  @media screen and (min-width: 990px) {
    header-drawer {
      display: flex !important;
    }
  }

  /* ---- Responsive: Mobile (< 990px) ---- */
  @media screen and (max-width: 989px) {
    .prada-header {
      padding: 10px 16px !important;
    }

    /* Hide text labels on mobile */
    .prada-menu-text,
    .prada-search-text,
    .prada-header-btn__label {
      display: none !important;
    }

    /* Hide contact and wishlist on mobile */
    .prada-header-btn--contact,
    .prada-header-btn--wishlist {
      display: none !important;
    }

    .prada-header-btn,
    .prada-header .header__icon {
      width: 32px !important;
      height: 32px !important;
      padding: 0 !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      margin: 0 !important;
    }

    .prada-header {
      position: relative !important;
      padding: 10px 16px !important;
    }

    .prada-header-left {
      flex: 1 1 0%;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 8px;
    }

    .prada-header-center {
      position: absolute !important;
      left: 50% !important;
      top: 50% !important;
      transform: translate(-50%, -50%) !important;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .prada-header-right {
      flex: 1 1 0%;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 8px;
    }

    .prada-text-logo {
      font-size: 20px;
      letter-spacing: 0.25em;
    }

    .prada-header-logo .header__heading-logo {
      max-width: 150px;
      max-height: 28px;
    }

    /* Make SVGs bolder on mobile */
    .prada-header svg {
      stroke-width: 2.2 !important;
    }
  }

  /* ---- Sticky header states ---- */
  .shopify-section-header-sticky .header-wrapper {
    background: rgba(255, 255, 255, 0) !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
  }

  .shopify-section-header-sticky .section-header {
    position: fixed !important;
  }

  .shopify-section-header-hidden .header-wrapper {
    transform: none !important;
    transition: none !important;
  }

  .animate .header-wrapper {
    transition: transform 0.3s ease, background 0.3s ease;
  }

  /* Prada Hover Transition & Interactions */
  .header-wrapper,
  .prada-header-btn,
  .prada-header-btn__label,
  .prada-header-logo,
  .prada-text-logo,
  .prada-header header-drawer summary.header__icon,
  .prada-header header-drawer summary .prada-menu-text,
  .prada-header .header__search summary.header__icon,
  .prada-header .header__search summary .prada-search-text,
  .prada-header .header__icon--account,
  .prada-header .header__icon--cart,
  .prada-header-btn__icon svg,
  .prada-header header-drawer summary .prada-menu-icon-wrapper svg,
  .prada-header .header__search summary .prada-search-icon-wrapper svg,
  .prada-header .header__icon--account svg,
  .prada-header .header__icon--cart svg,
  .prada-cart-badge {
    transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease, stroke 0.3s ease, opacity 0.3s ease !important;
  }

  /* --- DEFAULT STATE (Pages WITHOUT a Hero Banner, OR Scrolled Past Hero, OR Hovered) --- */
  .header-wrapper {
    background: #ffffff !important;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08) !important;
  }

  .prada-header-btn,
  .prada-header-btn__label,
  .prada-header-logo,
  .prada-text-logo,
  .prada-header header-drawer summary.header__icon,
  .prada-header header-drawer summary .prada-menu-text,
  .prada-header .header__search summary.header__icon,
  .prada-header .header__search summary .prada-search-text,
  .prada-header .header__icon--account,
  .prada-header .header__icon--cart {
    color: #000000 !important;
  }

  .prada-header-btn__icon svg,
  .prada-header header-drawer summary .prada-menu-icon-wrapper svg,
  .prada-header .header__search summary .prada-search-icon-wrapper svg,
  .prada-header .header__icon--account svg,
  .prada-header .header__icon--cart svg {
    stroke: #000000 !important;
  }

  .prada-cart-badge {
    background: #000000 !important;
    color: #ffffff !important;
  }

  .prada-header-logo .has-hover-logo .default-logo {
    display: none !important;
  }
  .prada-header-logo .has-hover-logo .hover-logo {
    display: block !important;
  }

  /* --- TRANSPARENT STATE (ONLY when on Hero Banner pages, NOT hovered, and NOT scrolled past hero) --- */
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) {
    background: rgba(255, 255, 255, 0) !important;
    border-bottom: none !important;
  }

  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header-btn,
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header-btn__label,
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header-logo,
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-text-logo,
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header header-drawer summary.header__icon,
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header header-drawer summary .prada-menu-text,
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header .header__search summary.header__icon,
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header .header__search summary .prada-search-text,
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .header__icon--account,
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .header__icon--cart {
    color: #ffffff !important;
  }

  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header-btn__icon svg,
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header header-drawer summary .prada-menu-icon-wrapper svg,
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header .header__search summary .prada-search-icon-wrapper svg,
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .header__icon--account svg,
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .header__icon--cart svg {
    stroke: #ffffff !important;
  }

  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-cart-badge {
    background: #ffffff !important;
    color: #000000 !important;
  }

  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header-logo .has-hover-logo .default-logo {
    display: block !important;
  }
  .header-wrapper.has-hero-banner:not(:hover):not(.scrolled-past-hero) .prada-header-logo .has-hover-logo .hover-logo {
    display: none !important;
  }

  /* Logo base definitions */
  .prada-header-logo .hover-logo {
    display: none !important;
  }
  .prada-header-logo .default-logo {
    display: block !important;
  }
</style>

{%- style -%}
  .header {
    padding: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px 3rem {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px 3rem;
  }

  .prada-header-logo .header__heading-logo {
    width: {{ settings.mobile_logo_width | default: 90 }}px !important;
    max-width: 100% !important;
    max-height: none !important;
  }

  @media screen and (min-width: 990px) {
    .prada-header-logo .header__heading-logo {
      width: {{ settings.logo_width }}px !important;
    }
  }

  .section-header {
    position: sticky; /* This is for fixing a Safari z-index issue. PR #2147 */
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .header {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

{%- liquid
  for block in section.blocks
    if block.type == '@app'
      assign has_app_block = true
    endif
  endfor
-%}

{% liquid
  assign header_tag = 'div'

  if section.settings.sticky_header_type != 'none'
    assign header_tag = 'sticky-header'
  endif
%}

<{{ header_tag }}
  {% if header_tag == 'sticky-header' %}
    data-sticky-type="{{ section.settings.sticky_header_type }}"
  {% endif %}
  class="header-wrapper color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %}"
>
  {%- liquid
    assign social_links = false
    assign localization_forms = false

    if settings.social_twitter_link != blank or settings.social_facebook_link != blank or settings.social_pinterest_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_vimeo_link != blank or settings.social_tiktok_link != blank or settings.social_tumblr_link != blank or settings.social_snapchat_link != blank
      assign social_links = true
    endif

    if localization.available_countries.size > 1 and section.settings.enable_country_selector or section.settings.enable_language_selector and localization.available_languages.size > 1
      assign localization_forms = true
    endif
  -%}
  <header class="header prada-header{% if section.settings.menu_type_desktop == 'drawer' %} drawer-menu{% endif %}{% if section.settings.menu != blank %} header--has-menu{% endif %}" role="banner">
    
    {%- comment -%} LEFT: Menu + Search {%- endcomment -%}
    <div class="prada-header-left">
      {%- if section.settings.menu != blank -%}
        {% render 'header-drawer' %}
      {%- endif -%}
      {% render 'header-search', input_id: 'Search-In-Modal-1' %}
    </div>

    {%- comment -%} CENTER: Logo {%- endcomment -%}
    <div class="prada-header-center">
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">
      {%- endif -%}
      <a href="{{ routes.root_url }}" class="header__heading-link prada-header-logo link link--text focus-inset">
        {%- if settings.logo != blank -%}
          <div class="header__heading-logo-wrapper{% if settings.logo_hover != blank %} has-hover-logo{% endif %}">
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            {% capture sizes %}(min-width: 750px) {{ settings.logo_width }}px, 50vw{% endcapture %}
            {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
            {{
              settings.logo
              | image_url: width: 600
              | image_tag:
                class: 'header__heading-logo default-logo',
                widths: widths,
                height: logo_height,
                width: settings.logo_width,
                alt: logo_alt,
                sizes: sizes,
                preload: true
            }}
            {%- if settings.logo_hover != blank -%}
              {%- assign logo_hover_height = settings.logo_width | divided_by: settings.logo_hover.aspect_ratio -%}
              {{
                settings.logo_hover
                | image_url: width: 600
                | image_tag:
                  class: 'header__heading-logo hover-logo',
                  widths: widths,
                  height: logo_hover_height,
                  width: settings.logo_width,
                  alt: logo_alt,
                  sizes: sizes,
                  preload: true
              }}
            {%- endif -%}
          </div>
        {%- else -%}
          <span class="prada-text-logo">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}
    </div>

    {%- comment -%} RIGHT: Contact us, Wishlist, Account, Cart {%- endcomment -%}
    <div class="prada-header-right">
      <a href="/pages/contact" class="prada-header-btn prada-header-btn--contact">
        <span class="prada-header-btn__label">Contact us</span>
      </a>
      
      <a href="#" class="prada-header-btn prada-header-btn--wishlist" aria-label="View your wish list">
        <span class="prada-header-btn__icon">
          {{- 'prada-wishlist.svg' | inline_asset_content -}}
        </span>
      </a>

      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="prada-header-btn prada-header-btn--account"
          rel="nofollow"
          aria-label="Account"
        >
          <span class="prada-header-btn__icon">
            {{- 'prada-account.svg' | inline_asset_content -}}
          </span>
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="prada-header-btn prada-header-btn--cart" id="cart-icon-bubble" aria-label="{{ 'templates.cart.cart' | t }}">
        <span class="prada-header-btn__icon">
          {{- 'prada-cart.svg' | inline_asset_content -}}
        </span>
        {%- if cart.item_count > 0 -%}
          <span class="prada-cart-badge" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
        <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
      </a>
    </div>
  </header>
</{{ header_tag }}>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification',
    color_scheme: section.settings.color_scheme,
    desktop_menu_type: section.settings.menu_type_desktop
  -%}
{%- endif -%}

{% javascript %}
  class StickyHeader extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      this.header = document.querySelector('.section-header');
      this.headerIsAlwaysSticky =
        this.getAttribute('data-sticky-type') === 'always' ||
        this.getAttribute('data-sticky-type') === 'reduce-logo-size';
      this.headerBounds = {};

      this.setHeaderHeight();

      window.matchMedia('(max-width: 990px)').addEventListener('change', this.setHeaderHeight.bind(this));

      if (this.headerIsAlwaysSticky) {
        this.header.classList.add('shopify-section-header-sticky');
      }

      this.currentScrollTop = 0;
      this.preventReveal = false;
      this.predictiveSearch = this.querySelector('predictive-search');

      this.onScrollHandler = this.onScroll.bind(this);
      this.hideHeaderOnScrollUp = () => (this.preventReveal = true);

      this.addEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.addEventListener('scroll', this.onScrollHandler, false);

      this.createObserver();
      this.initHeroBannerDetection();
    }

    initHeroBannerDetection() {
      const headerWrapper = this.querySelector('.header-wrapper') || document.querySelector('.header-wrapper');
      if (!headerWrapper) return;

      const banner = document.querySelector('.banner, .image-banner, .slideshow, [class*="banner"]');
      if (banner) {
        headerWrapper.classList.add('has-hero-banner');
        const onScroll = () => {
          const scrollY = window.pageYOffset || document.documentElement.scrollTop;
          const threshold = banner.offsetHeight / 2;
          if (scrollY >= threshold) {
            headerWrapper.classList.add('scrolled-past-hero');
          } else {
            headerWrapper.classList.remove('scrolled-past-hero');
          }
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
    }

    setHeaderHeight() {
      document.documentElement.style.setProperty('--header-height', `${this.header.offsetHeight}px`);
    }

    disconnectedCallback() {
      this.removeEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.removeEventListener('scroll', this.onScrollHandler);
    }

    createObserver() {
      let observer = new IntersectionObserver((entries, observer) => {
        this.headerBounds = entries[0].intersectionRect;
        observer.disconnect();
      });

      observer.observe(this.header);
    }

    onScroll() {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

      if (this.predictiveSearch && this.predictiveSearch.isOpen) return;

      if (scrollTop > this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        this.header.classList.add('scrolled-past-header');
        if (this.preventHide) return;
        requestAnimationFrame(this.hide.bind(this));
      } else if (scrollTop < this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        this.header.classList.add('scrolled-past-header');
        if (!this.preventReveal) {
          requestAnimationFrame(this.reveal.bind(this));
        } else {
          window.clearTimeout(this.isScrolling);

          this.isScrolling = setTimeout(() => {
            this.preventReveal = false;
          }, 66);

          requestAnimationFrame(this.hide.bind(this));
        }
      } else if (scrollTop <= this.headerBounds.top) {
        this.header.classList.remove('scrolled-past-header');
        requestAnimationFrame(this.reset.bind(this));
      }

      this.currentScrollTop = scrollTop;
    }

    hide() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.add('shopify-section-header-hidden', 'shopify-section-header-sticky');
      this.closeMenuDisclosure();
      this.closeSearchModal();
    }

    reveal() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.add('shopify-section-header-sticky', 'animate');
      this.header.classList.remove('shopify-section-header-hidden');
    }

    reset() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.remove('shopify-section-header-hidden', 'shopify-section-header-sticky', 'animate');
    }

    closeMenuDisclosure() {
      this.disclosures = this.disclosures || this.header.querySelectorAll('header-menu');
      this.disclosures.forEach((disclosure) => disclosure.close());
    }

    closeSearchModal() {
      this.searchModal = this.searchModal || this.header.querySelector('details-modal');
      this.searchModal.close(false);
    }
  }

  customElements.define('sticky-header', StickyHeader);
{% endjavascript %}

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

