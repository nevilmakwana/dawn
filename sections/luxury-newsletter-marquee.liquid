<!-- Newsletter Block -->
<section class="py-32 bg-ink text-white" data-section-id="{{ section.id }}">
    <div class="max-w-[1440px] mx-auto px-8 text-center">
        <h2 class="text-3xl font-display mb-4">Stay in the World of Prada</h2>
        <p class="text-white/60 text-sm mb-12 max-w-xl mx-auto">Subscribe to receive exclusive updates on new collections, events, and behind-the-scenes stories.</p>

        <form class="max-w-md mx-auto flex border border-white/20 p-1" onsubmit="return false;">
            <input type="email" placeholder="Email Address" class="bg-transparent flex-1 px-6 py-4 text-sm text-white placeholder-white/40 focus:outline-none">
            <button class="bg-black text-white px-8 py-4 text-xs uppercase tracking-widest hover:bg-white hover:text-black transition-colors">Join</button>
        </form>

        <!-- Marquee -->
        <div class="mt-24 overflow-hidden whitespace-nowrap relative w-full">
            <div class="inline-flex animate-slide items-center gap-16">
                <!-- Group 1 -->
                <span class="font-display text-2xl tracking-[0.2em] opacity-30">PRADA</span>
                <span class="text-white/20 text-2xl">✦</span>
                <span class="font-display text-2xl tracking-[0.2em] opacity-30 italic">Milano</span>
                <span class="text-white/20 text-2xl">✦</span>
                <span class="font-display text-2xl tracking-[0.2em] opacity-30">PRADA</span>
                <span class="text-white/20 text-2xl">✦</span>
                <span class="font-display text-2xl tracking-[0.2em] opacity-30 italic">Since 1913</span>
                <span class="text-white/20 text-2xl">✦</span>
                
                <!-- Group 2 (Duplicate for infinite scroll) -->
                <span class="font-display text-2xl tracking-[0.2em] opacity-30">PRADA</span>
                <span class="text-white/20 text-2xl">✦</span>
                <span class="font-display text-2xl tracking-[0.2em] opacity-30 italic">Milano</span>
                <span class="text-white/20 text-2xl">✦</span>
                <span class="font-display text-2xl tracking-[0.2em] opacity-30">PRADA</span>
                <span class="text-white/20 text-2xl">✦</span>
                <span class="font-display text-2xl tracking-[0.2em] opacity-30 italic">Since 1913</span>
                <span class="text-white/20 text-2xl">✦</span>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "UXPilot Newsletter",
  "settings": [],
  "presets": [
    {
      "name": "UXPilot Newsletter"
    }
  ]
}
{% endschema %}
