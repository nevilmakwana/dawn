<div class="luxury-section" data-section-id="{{ section.id }}">
  <div class="editorial-grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="editorial-card" {{ block.shopify_attributes }}>
        <div class="editorial-card__media">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {%- else -%}
          {%- case forloop.index -%}
            {%- when 1 -%}
              {%- assign dummy_image = "https://images.unsplash.com/photo-1509319117193-57bab727e09d?q=80&w=1000&auto=format&fit=crop" -%}
            {%- when 2 -%}
              {%- assign dummy_image = "https://images.unsplash.com/photo-1483985988355-763728e1935b?q=80&w=1000&auto=format&fit=crop" -%}
            {%- else -%}
              {%- assign dummy_image = "https://images.unsplash.com/photo-1490481651871-ab68de25d43d?q=80&w=1000&auto=format&fit=crop" -%}
          {%- endcase -%}
          <img src="{{ dummy_image }}" alt="Editorial" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
          {%- endif -%}
        </div>
        {%- if block.settings.tag != blank -%}
          <div class="editorial-card__tag">{{ block.settings.tag }}</div>
        {%- endif -%}
        <h3 class="editorial-card__title">{{ block.settings.title }}</h3>
        <span class="btn btn--link">Discover</span>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Luxury Editorial Grid",
  "settings": [],
  "blocks": [
    {
      "type": "article",
      "name": "Editorial Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "tag",
          "default": "CAMPAIGN",
          "label": "Tag/Category"
        },
        {
          "type": "text",
          "id": "title",
          "default": "The Spring Collection",
          "label": "Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxury Editorial Grid",
      "blocks": [
        { "type": "article" },
        { "type": "article" },
        { "type": "article" }
      ]
    }
  ]
}
{% endschema %}
