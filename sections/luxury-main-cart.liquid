{{ 'luxury-pages.css' | asset_url | stylesheet_tag }}

<div class="luxury-page" data-section-id="{{ section.id }}">
  <div class="luxury-page__header">
    <h1 class="luxury-page__title">Shopping Bag</h1>
  </div>

  {%- if cart.item_count > 0 -%}
    <form action="{{ routes.cart_url }}" method="post" id="cart">
      <table class="cart-page-table">
        <thead>
          <tr>
            <th colspan="2">Product</th>
            <th>Quantity</th>
            <th style="text-align: right;">Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            <tr>
              <td style="width: 120px;">
                <div class="cart-page-item__media">
                  {%- if item.image -%}
                    {{ item.image | image_url: width: 300 | image_tag: loading: 'lazy' }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
              </td>
              <td>
                <div class="cart-page-item__details">
                  <a href="{{ item.url }}" class="cart-page-item__title">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <div class="cart-page-item__variant">{{ item.variant.title }}</div>
                  {%- endunless -%}
                  <a href="{{ item.url_to_remove }}" style="font-size: var(--fs-xs); color: var(--color-grey-600); margin-top: var(--space-4); text-transform: uppercase;">Remove</a>
                </div>
              </td>
              <td>
                <input type="number" name="updates[]" id="updates_{{ item.key }}" value="{{ item.quantity }}" min="0" style="width: 60px; text-align: center; border: 1px solid var(--color-border); padding: var(--space-2);">
              </td>
              <td style="text-align: right; font-size: var(--fs-base);">
                {{ item.final_line_price | money }}
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>

      <div class="cart-page-footer">
        <div class="cart-page-subtotal">
          <span>Subtotal</span>
          {{ cart.total_price | money }}
        </div>
        <p style="font-size: var(--fs-sm); color: var(--color-grey-600); margin-bottom: var(--space-6);">Taxes and shipping calculated at checkout.</p>
        
        <button type="submit" name="update" class="btn btn--secondary" style="margin-bottom: var(--space-4);">Update Bag</button>
        <button type="submit" name="checkout" class="btn btn--primary cart-page-checkout">Checkout</button>
      </div>
    </form>
  {%- else -%}
    <div style="text-align: center; margin-top: var(--space-12);">
      <p style="margin-bottom: var(--space-8);">Your shopping bag is currently empty.</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Discover the Collection</a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Luxury Cart Page",
  "settings": []
}
{% endschema %}
