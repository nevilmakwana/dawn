<!-- Category Grid -->
<section id="categories" class="py-24 bg-surface" data-section-id="{{ section.id }}">
    <div class="max-w-[1440px] mx-auto px-8 grid grid-cols-1 md:grid-cols-4 gap-8">
        <!-- Card 1 -->
        <div class="group cursor-pointer">
            <div class="relative aspect-[3/4] overflow-hidden mb-6">
                <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="https://storage.googleapis.com/uxpilot-auth.appspot.com/gen_bba2bb0216_27b5e29cd18e89c0.png" alt="Women" />
                <div class="absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-colors"></div>
                <div class="absolute inset-0 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                    <span class="text-white text-sm uppercase tracking-widest border-b border-white pb-1">Women</span>
                </div>
            </div>
            <div class="text-center">
                <h3 class="text-sm uppercase tracking-widest text-gray-900 mb-1">Women</h3>
                <p class="text-xs text-muted">124 Pieces</p>
            </div>
        </div>

        <!-- Card 2 -->
