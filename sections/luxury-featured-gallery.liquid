<!-- Gallery Section -->
<section class="py-24 bg-surface2" data-section-id="{{ section.id }}">
    <div class="max-w-[1440px] mx-auto px-8">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-display text-gray-900 tracking-wide">FEATURED PIECES</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Gallery Item 1 -->
            <div class="group cursor-pointer">
                <div class="relative aspect-[4/5] overflow-hidden">
                    <img class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110 grayscale group-hover:grayscale-0" src="https://storage.googleapis.com/uxpilot-auth.appspot.com/gen_0d6fcfda2b_d0f3295f5a65c3c7.png" alt="Re-Nylon Bag" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="absolute bottom-6 left-6 opacity-0 group-hover:opacity-100 transition-opacity translate-y-4 group-hover:translate-y-0">
                        <span class="text-white text-xs uppercase tracking-widest">Re-Nylon Bag</span>
                        <p class="text-white/80 text-xs mt-1">€2,100</p>
                    </div>
                </div>
            </div>

            <!-- Gallery Item 2 -->
            <div class="group cursor-pointer">
                <div class="relative aspect-[4/5] overflow-hidden">
                    <img class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110 grayscale group-hover:grayscale-0" src="https://storage.googleapis.com/uxpilot-auth.appspot.com/gen_71440aa1b1_4e55cffc27b15ea0.png" alt="Sculptural Heels" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="absolute bottom-6 left-6 opacity-0 group-hover:opacity-100 transition-opacity translate-y-4 group-hover:translate-y-0">
                        <span class="text-white text-xs uppercase tracking-widest">Sculptural Heels</span>
                        <p class="text-white/80 text-xs mt-1">€950</p>
                    </div>
                </div>
            </div>

            <!-- Gallery Item 3 -->
            <div class="group cursor-pointer">
                <div class="relative aspect-[4/5] overflow-hidden">
                    <img class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110 grayscale group-hover:grayscale-0" src="https://storage.googleapis.com/uxpilot-auth.appspot.com/gen_e6128053d8_ff7da6b6492098e5.png" alt="Wool Overcoat" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="absolute bottom-6 left-6 opacity-0 group-hover:opacity-100 transition-opacity translate-y-4 group-hover:translate-y-0">
                        <span class="text-white text-xs uppercase tracking-widest">Wool Overcoat</span>
                        <p class="text-white/80 text-xs mt-1">€3,400</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "UXPilot Featured Gallery",
  "settings": [],
  "presets": [
    {
      "name": "UXPilot Featured Gallery"
    }
  ]
}
{% endschema %}
