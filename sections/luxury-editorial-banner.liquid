<!-- Editorial Banner -->
<section class="py-24 bg-surface" data-section-id="{{ section.id }}">
    <div class="max-w-[1440px] mx-auto px-8">
        <div class="relative aspect-video overflow-hidden group">
            <img class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" src="https://storage.googleapis.com/uxpilot-auth.appspot.com/gen_04b03aaa78_2693bbb87519940d.png" alt="THE ART OF CRAFTSMANSHIP" />
            <div class="absolute inset-0 bg-black/40"></div>
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
                <h2 class="text-white font-display text-5xl md:text-7xl mb-4">THE ART OF <br><span class="italic">CRAFTSMANSHIP</span></h2>
                <div class="w-24 h-[1px] bg-white/50"></div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "UXPilot Editorial Banner",
  "settings": [],
  "presets": [
    {
      "name": "UXPilot Editorial Banner"
    }
  ]
}
{% endschema %}
