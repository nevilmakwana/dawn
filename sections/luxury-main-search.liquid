{{ 'luxury-pages.css' | asset_url | stylesheet_tag }}
{{ 'luxury-collection.css' | asset_url | stylesheet_tag }}

<div class="luxury-page" data-section-id="{{ section.id }}">
  <div class="luxury-page__header">
    <h1 class="luxury-page__title">
      {%- if search.performed -%}
        Search Results
      {%- else -%}
        Search
      {%- endif -%}
    </h1>
  </div>

  <form action="{{ routes.search_url }}" method="get" role="search" class="search-form-page">
    <input type="hidden" name="type" value="product">
    <input 
      type="search" 
      name="q" 
      value="{{ search.terms | escape }}" 
      placeholder="Search for products..." 
      aria-label="Search">
    <button type="submit" aria-label="Submit">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </button>
  </form>

  {%- if search.performed -%}
    <div class="search-results-count">
      {{ search.results_count }} results found for "{{ search.terms }}"
    </div>

    {%- if search.results_count == 0 -%}
      <div style="text-align: center; margin-top: var(--space-12);">
        <p>Your search did not yield any results. Please try different keywords.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--link">Shop All</a>
      </div>
    {%- else -%}
      {%- paginate search.results by 16 -%}
        <div class="collection-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'luxury-product-card', product_card_product: item, show_secondary_image: true, show_vendor: false %}
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="pagination">
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="pagination__item">{{ part.title }}</a>
              {%- else -%}
                <span class="pagination__item {% if part.title == paginate.current_page %}pagination__item--current{% endif %}">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Luxury Search",
  "settings": []
}
{% endschema %}
